# Environment config loader example

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
# DATABASE_TYPE: 'sqlite' for local dev, 'postgres' for production
DATABASE_TYPE=sqlite
DATABASE_PATH=data/database.sqlite
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/ibemdb

# Redis
# Set to 'true' to use a real Redis server, 'false' for in-memory mock
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# Media uploads directory
UPLOAD_DIR=uploads

# Security
# RS256 JWT Public/Private Keys (base64 encoded or path to files)
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem

# Master Encryption Key (32 bytes hex - 64 characters)
MASTER_ENCRYPTION_KEY=your_64_character_hex_master_encryption_key_here

# Backup Encryption Key (32 bytes hex - 64 characters)
BACKUP_ENCRYPTION_KEY=your_64_character_hex_backup_encryption_key_here
