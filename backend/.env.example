# Environment config loader example

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://ibemuser:ibempass@localhost:5432/ibemdb

# Redis
REDIS_URL=redis://localhost:6379

# MinIO Object Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=ibemcom-media

# Security
# RS256 JWT Public/Private Keys (base64 encoded or path to files)
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem

# Master Encryption Key (32 bytes hex - 64 characters)
MASTER_ENCRYPTION_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f

# Backup Encryption Key (32 bytes hex - 64 characters)
BACKUP_ENCRYPTION_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
